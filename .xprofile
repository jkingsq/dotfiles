#!/bin/sh
#. /etc/X11/xinit/xprofile

xscreensaver &
xss-lock -- xscreensaver-command --lock &

xbindkeys -p

xmodmap ~/.xmodmap

compton --backend glx --inactive-dim 0.3 --menu-opacity 0.7 --inactive-opacity 1.0 --fade-delta 5 &

xset -b

xrandr --output DVI-D-0 --rotate right --dpi 128
xrandr --output DVI-D-0 --right-of DP-0
xset -dpms
xset s off
